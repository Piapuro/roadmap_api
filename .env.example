# ==============================
# サーバー設定
# ==============================
APP_ENV=development
PORT=8080
GEMINI_API_KEY=
WEBHOOK_SECRET=

# ==============================
# Supabase（全環境共通）
# ==============================
SUPABASE_URL=https://xxxxxxxxxx.supabase.co
SUPABASE_ANON_KEY=CHANGE_ME
SUPABASE_SERVICE_KEY=CHANGE_ME
SUPABASE_JWT_SECRET=CHANGE_ME

# ==============================
# データベース
# ==============================
# 開発環境: docker-compose の db コンテナに接続
# 本番環境: Supabase の接続文字列に変える
DATABASE_URL=postgres://dev_user:dev_password@db:5432/roadmap_dev?sslmode=disable

# ==============================
# Redis
# ==============================
# 開発環境: docker-compose の redis コンテナに接続
# 本番環境: Upstash や Memorystore のアドレスに変える
REDIS_ADDR=redis:6379

# ==============================
# AI API
# ==============================
CLAUDE_API_KEY=CHANGE_ME

# ==============================
# CORS
# ==============================
# 開発環境: localhost:3000
# 本番環境: Vercel のドメインに変える
CORS_ALLOW_ORIGINS=http://localhost:3000
