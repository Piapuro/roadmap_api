FROM golang:1.24-alpine

# Air（ホットリロード）と git をインストール
RUN apk add --no-cache git && \
    go install github.com/air-verse/air@v1.61.0

WORKDIR /app

# 依存関係を先にコピー（レイヤーキャッシュ効率化）
COPY go.mod go.sum ./
RUN go mod download

# ソースコードは volume マウントで反映するため COPY 不要

EXPOSE 8080

CMD ["air", "-c", ".air.toml"]
